{
  "name": "punchpress",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:desktop": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/web build",
    "build:web": "bun run --cwd apps/web build",
    "build:desktop": "bun run --cwd apps/desktop build",
    "build:desktop:unsigned": "bun run --cwd apps/desktop build:unsigned",
    "preview": "bun run --cwd apps/web preview",
    "publish:desktop": "bun run --cwd apps/desktop publish",
    "release:bump": "node scripts/release/bump-version.mjs",
    "release:notes": "node scripts/release/extract-release-notes-from-changelog.mjs",
    "release:collect-changelog-context": "node scripts/release/collect-changelog-context.mjs",
    "release:check": "node scripts/release/validate-release-metadata.mjs",
    "release:check-desktop-artifacts": "node scripts/release/check-desktop-artifacts.mjs",
    "lint": "bun run --cwd apps/web lint",
    "lint:fix": "bun run --cwd apps/web lint:fix",
    "check": "bun run --cwd apps/web check",
    "fix": "bun run --cwd apps/web fix",
    "playwright:install": "playwright install chromium",
    "test:editor": "bun test apps/web/tests/editor-contract",
    "test:editor:watch": "bun test --watch apps/web/tests/editor-contract",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
