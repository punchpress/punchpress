    "opentype.js": "1.3.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "9.2.1",
    "ultracite": "7.2.4",
    "vite": "7.3.1"
