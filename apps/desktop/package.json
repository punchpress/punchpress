{
  "name": "@punchpress/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "description": "The Electron desktop app for PunchPress.",
  "scripts": {
    "dev": "bun run scripts/dev-desktop.ts",
    "build": "bun run clean && bun run build:web && bun run build:electron",
    "build:web": "bun run --cwd ../web build",
    "build:electron": "dotenv -e ../../.env -- sh -c 'electron-vite build && electron-builder --mac'",
    "build:unsigned": "electron-vite build && electron-builder --mac --config.mac.identity=null --config.mac.notarize=false",
    "clean": "rimraf artifacts out",
    "publish": "dotenv -e ../../.env -- sh -c 'bun run clean && bun run build:web && electron-vite build && electron-builder --mac --publish always'"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "dotenv-cli": "^11.0.0",
    "electron": "39.2.7",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "rimraf": "^5.0.5"
  }
}
