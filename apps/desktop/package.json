{
  "name": "@punchpress/desktop",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev-desktop.ts",
    "dev:app": "bun run prepare:runtime && electrobun dev --watch",
    "dev:web": "bun run --cwd ../web dev",
    "build": "bun run build:web && bun run prepare:runtime && electrobun build --env=stable",
    "build:web": "bun run --cwd ../web build",
    "prepare:runtime": "bun run scripts/ensure-electrobun-runtime.ts",
    "run": "bun run prepare:runtime && electrobun run"
  },
  "dependencies": {
    "electrobun": "1.15.1"
  }
}
